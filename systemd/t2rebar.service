[Unit]
Description=T2ReBAR — resize PCIe BARs on Mac Pro 2019 GPUs
Documentation=https://github.com/yiminyuan/T2ReBAR
After=sysinit.target
Before=display-manager.service t2fanrd.service graphical.target
ConditionKernelCommandLine=pci=realloc

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/t2rebar execute --target=planned --yes
SyslogIdentifier=t2rebar

[Install]
WantedBy=multi-user.target
